import { PrimaryButton } from "./primary-button.slint";

export component TreesRail inherits Rectangle {
    in property <[string]> tree_names: [];
    in property <[int]> tree_ids: [];
    in property <int> selected_tree_id: -1;

    callback tree_selected(int);

    background: #f7f1ea;
    border-radius: 18px;
    border-color: #e6dacc;
    border-width: 1px;

    VerticalLayout {
        padding: 20px;
        spacing: 16px;

        Text {
            text: "Trees";
            font-size: 22px;
            font-weight: 600;
            color: #5b4738;
        }

        Text {
            text: root.tree_names.length > 0 ? "Choose a tree to open its workspace." : "Your trees will appear here.";
            wrap: word-wrap;
            color: #8a7665;
        }

        Rectangle {
            vertical-stretch: 1;
            background: #fffaf5;
            border-radius: 14px;
            border-color: #eadfce;
            border-width: 1px;

            VerticalLayout {
                padding: 12px;
                spacing: 10px;

                for tree_name[index] in root.tree_names : TouchArea {
                    height: 42px;

                    clicked => {
                        root.tree_selected(root.tree_ids[index]);
                    }

                    Rectangle {
                        width: parent.width;
                        height: parent.height;
                        background: root.selected_tree_id == root.tree_ids[index] ? #ead8c5 : #f3e7da;
                        border-radius: 12px;
                        border-width: root.selected_tree_id == root.tree_ids[index] ? 1px : 0px;
                        border-color: #d5b898;

                        Text {
                            x: 12px;
                            y: 12px;
                            text: tree_name;
                            color: root.selected_tree_id == root.tree_ids[index] ? #4f3b2e : #6b5645;
                        }
                    }
                }
            }
        }

        PrimaryButton {
            text: "+ New Tree";
        }
    }
}
